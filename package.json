{
  "name": "onekey-react",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://smiles0527.github.io/Onekey",
  "dependencies": {
    "@hookform/resolvers": "^2.9.7",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.11.45",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "date-fns": "^2.29.1",
    "firebase": "^12.6.0",
    "framer-motion": "^12.26.1",
    "lucide-react": "^0.460.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.33.1",
    "react-router-dom": "^6.30.3",
    "react-scripts": "^5.0.1",
    "typescript": "^4.7.4",
    "web-vitals": "^2.1.4",
    "yup": "^0.32.11",
    "zustand": "^4.0.0"
  },
  "scripts": {
    "start": "npm run dev",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "react-scripts start",
    "dev:backend": "cd backend && npm run dev",
    "dev:full": "concurrently \"npm run dev:backend\" \"wait-on http://localhost:3001 && npm run dev:frontend\"",
    "install:all": "npm install && cd backend && npm install",
    "setup": "npm run install:all && cd backend && npm run migrate && npm run seed",
    "build:all": "npm run build && cd backend && npm run build",
    "start:prod": "cd backend && npm start",
    "deploy:setup": "scripts/deploy.sh",
    "deploy:start": "cd backend && npm start",
    "test:integration": "node scripts/test-integration.js",
    "start:dev": "scripts/start-dev.sh"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "wait-on": "^8.0.4"
  }
}
